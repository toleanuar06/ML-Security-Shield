{
  "manifest_version": 3,
  "name": "ML Security Shield",
  "version": "1.0",
  "description": "Машиналық оқыту арқылы қауіпті сайттарды бұғаттайды.",
  "permissions": ["tabs", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:8000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ML Shield"
  }
}